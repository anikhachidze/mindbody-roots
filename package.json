{
  "name": "mindbody-roots",
  "version": "0.1.0",
  "private": true,
  "description": "A calm Next.js health blog and affiliate landing page about mind-body habits.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prepare": "husky install"
    ,
    "lighthouse": "npx lighthouse http://localhost:3000 --output html --output-path ./lighthouse-report.html"
  },
  "keywords": [
    "nextjs",
    "react",
    "health",
    "wellness",
    "blog",
    "affiliate"
  ],
  "author": "Ani Khachidze <ani@khachidze.eu>",
  "license": "MIT",
  "dependencies": {
    "next": "^13.5.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "prettier": "^2.8.8",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.3",
    "lint-staged": "^14.0.0",
    "jest": "^29.6.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/user-event": "^14.4.3",
    "babel-jest": "^29.6.1",
    "@babel/preset-env": "^7.22.20",
    "@babel/preset-react": "^7.22.15",
    "next/jest": "^13.5.11",
    "jest-environment-jsdom": "^29.5.0",
    "axe-core": "^4.8.4",
    "jest-axe": "^6.3.1"
  }
}
